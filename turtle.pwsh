# --- TURTLE SHIELD: WINDOWS/PWSH INITIALIZATION ---
Write-Host "🐢 Initializing Turtle Shield for PowerShell (v3.0)..." -ForegroundColor Cyan

# 1. Verification
if (!(Get-Command python -ErrorAction SilentlyContinue)) {
    Write-Host "📦 Installing Python via winget..." -ForegroundColor Yellow
    winget install -e --id Python.Python.3.11 --accept-package-agreements --accept-source-agreements
}

if (!(Get-Command ollama -ErrorAction SilentlyContinue)) {
    Write-Host "📦 Installing Ollama Compute..." -ForegroundColor Yellow
    winget install -e --id Ollama.Ollama --accept-package-agreements --accept-source-agreements
}

# 2. Dependencies
Write-Host "🐍 Installing Python stack..." -ForegroundColor Magenta
pip install discord.py flask flask-cors requests cryptography

# 3. Vault & Routing
$VaultPaths = @("turtle_vault/logs", "turtle_vault/compliance", "turtle_vault/agents")
foreach ($Path in $VaultPaths) { if (!(Test-Path $Path)) { New-Item -ItemType Directory -Path $Path -Force | Out-Null } }

$TurtleFunc = @"
function turtle {
    python `"`$(Get-Location)/main.py`" @args
}
"@

if (!(Test-Path $PROFILE)) { New-Item -ItemType File -Path $PROFILE -Force | Out-Null }
if (!(Get-Content $PROFILE | Select-String "function turtle")) {
    Add-Content -Path $PROFILE -Value "`n$TurtleFunc"
}

Invoke-Expression $TurtleFunc
Write-Host "`n🛡️ Setup Complete. Type 'turtle' to engage." -ForegroundColor Cyan
